{
  "tests": [
    {
      "name": "Fix unescaped ampersand",
      "method": "POST",
      "path": "/",
      "body": {
        "xml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<data><item id=\"1\">Price: 100 & 200</item></data>"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "report": {
          "status": "success"
        }
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Fix missing declaration with cyrillic",
      "method": "POST",
      "path": "/",
      "body": {
        "xml": "<root><item>Привет мир</item></root>"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "report": {
          "status": "success"
        }
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Empty body rejected",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    }
  ]
}
