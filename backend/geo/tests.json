{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "suggest — пустой query возвращает []",
      "method": "GET",
      "path": "/?action=suggest&query=",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "exact"
    },
    {
      "name": "fix — неизвестный action",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 400
    },
    {
      "name": "reverse — без координат",
      "method": "GET",
      "path": "/?action=reverse",
      "expectedStatus": 400
    },
    {
      "name": "reverse — центр Краснодара",
      "method": "GET",
      "path": "/?action=reverse&lat=45.0355&lng=38.9753",
      "expectedStatus": 200,
      "expectedBody": {"found": true},
      "bodyMatcher": "partial"
    }
  ]
}