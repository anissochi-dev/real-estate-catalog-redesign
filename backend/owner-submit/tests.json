{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET token — выдача токена",
      "method": "GET",
      "path": "/?action=token",
      "expectedStatus": 200,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Honeypot сработал — тихий успех",
      "method": "POST",
      "path": "/",
      "body": { "website": "http://spam.ru", "owner_name": "bot" },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "POST без токена — ошибка",
      "method": "POST",
      "path": "/",
      "body": { "owner_name": "Иван", "owner_phone": "+79991234567", "form_token": "" },
      "expectedStatus": 400,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}
