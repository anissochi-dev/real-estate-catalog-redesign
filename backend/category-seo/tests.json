{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET без category — 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": { "error": "category is required" },
      "bodyMatcher": "partial"
    },
    {
      "name": "GET с неизвестной категорией — 400",
      "method": "GET",
      "path": "/?category=unknown_xyz",
      "expectedStatus": 400,
      "expectedBody": { "error": "unknown category: unknown_xyz" },
      "bodyMatcher": "partial"
    }
  ]
}
