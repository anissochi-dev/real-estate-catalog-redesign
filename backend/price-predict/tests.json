{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET без id — 400",
      "method": "GET",
      "path": "/?foo=bar",
      "expectedStatus": 400,
      "expectedBody": {"error": "Не передан id объекта"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET ?ids= с некорректными значениями — 400",
      "method": "GET",
      "path": "/?ids=abc,xyz",
      "expectedStatus": 400,
      "expectedBody": {"error": "Не переданы корректные ids"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET ?ids= батч-режим — возвращает объект",
      "method": "GET",
      "path": "/?ids=1,2",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST без площади — 400",
      "method": "POST",
      "path": "/",
      "body": {"category": "office", "deal": "sale", "price": 5000000},
      "expectedStatus": 400,
      "expectedBody": {"error": "Не передана площадь объекта"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST расчёт прогноза",
      "method": "POST",
      "path": "/",
      "body": {"category": "office", "deal": "sale", "area": 100, "price": 8000000, "district": "Центр"},
      "expectedStatus": 200,
      "expectedBody": {"demand": {}, "price_assessment": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET price_market_stats — возвращает снапшоты",
      "method": "GET",
      "path": "/?action=price_market_stats&days=180",
      "expectedStatus": 200,
      "expectedBody": {"schedule": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "cost_approach — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "cost_approach"},
      "expectedStatus": 400
    },
    {
      "name": "nei — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "nei"},
      "expectedStatus": 400
    },
    {
      "name": "legal_risks — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "legal_risks"},
      "expectedStatus": 400
    },
    {
      "name": "tech_analysis — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "tech_analysis"},
      "expectedStatus": 400
    },
    {
      "name": "sensitivity — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "sensitivity"},
      "expectedStatus": 400
    },
    {
      "name": "financial_metrics — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "financial_metrics"},
      "expectedStatus": 400
    },
    {
      "name": "full_valuation — нет id → 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "full_valuation"},
      "expectedStatus": 400
    }
  ]
}