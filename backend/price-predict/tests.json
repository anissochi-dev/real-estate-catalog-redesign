{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET без id — 400",
      "method": "GET",
      "path": "/?foo=bar",
      "expectedStatus": 400,
      "expectedBody": {"error": "Не передан id объекта"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET ?ids= с некорректными значениями — 400",
      "method": "GET",
      "path": "/?ids=abc,xyz",
      "expectedStatus": 400,
      "expectedBody": {"error": "Не переданы корректные ids"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET ?ids= батч-режим — возвращает объект",
      "method": "GET",
      "path": "/?ids=1,2",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST без площади — 400",
      "method": "POST",
      "path": "/",
      "body": {"category": "office", "deal": "sale", "price": 5000000},
      "expectedStatus": 400,
      "expectedBody": {"error": "Не передана площадь объекта"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST расчёт прогноза",
      "method": "POST",
      "path": "/",
      "body": {"category": "office", "deal": "sale", "area": 100, "price": 8000000, "district": "Центр"},
      "expectedStatus": 200,
      "expectedBody": {"demand": {}, "price_assessment": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET price_market_stats — возвращает снапшоты",
      "method": "GET",
      "path": "/?action=price_market_stats&days=180",
      "expectedStatus": 200,
      "expectedBody": {"snapshots": [], "latest": [], "schedule": {}},
      "bodyMatcher": "partial"
    }
  ]
}