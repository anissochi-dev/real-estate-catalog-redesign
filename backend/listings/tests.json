{
  "tests": [
    {
      "name": "Получить все объявления",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Фильтр по категории",
      "method": "GET",
      "path": "/?category=office",
      "expectedStatus": 200
    },
    {
      "name": "Записать согласие пользователя",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "consent_save",
        "documents_opened": ["privacy", "personal"],
        "page_url": "/",
        "session_id": "test-session-1"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": { "success": true }
    },
    {
      "name": "POST без action — отклонено",
      "method": "POST",
      "path": "/",
      "body": { "foo": "bar" },
      "expectedStatus": 405
    }
  ]
}