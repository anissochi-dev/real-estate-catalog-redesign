# Заголовки безопасности для всех страниц — повышают репутацию сайта
# у антивирусов и браузеров, защищают от кликджекинга и подмены типов.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Permitted-Cross-Domain-Policies: none
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.poehali.dev https://mc.yandex.ru https://yandex.ru https://api-maps.yandex.ru https://vk.com https://mod.calltouch.ru https://telegram.org https://www.googletagmanager.com https://www.google-analytics.com https://fonts.googleapis.com https://2bishop.ru; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https: http:; connect-src 'self' https://functions.poehali.dev https://cdn.poehali.dev https://mc.yandex.ru https://api-maps.yandex.ru https://geocode-maps.yandex.ru https://www.google-analytics.com https://vk.com https://mod.calltouch.ru https://2bishop.ru https://llm.api.cloud.yandex.net https://bucket.poehali.dev; frame-src 'self' https://rutube.ru https://vk.com https://www.youtube.com; worker-src blob:; object-src 'none'; base-uri 'self'; form-action 'self';

# Статические ресурсы со встроенным хэшем в имени файла —
# кэшируются на год, браузер не перепроверяет до истечения срока.
# При новом деплое имя файла меняется → кэш автоматически сбрасывается.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Шрифты
*.woff2
  Cache-Control: public, max-age=31536000, immutable

*.woff
  Cache-Control: public, max-age=31536000, immutable

# Изображения (статические, из папки public)
*.png
  Cache-Control: public, max-age=31536000, immutable

*.jpg
  Cache-Control: public, max-age=31536000, immutable

*.jpeg
  Cache-Control: public, max-age=31536000, immutable

*.svg
  Cache-Control: public, max-age=31536000, immutable

*.webp
  Cache-Control: public, max-age=31536000, immutable

*.ico
  Cache-Control: public, max-age=31536000, immutable

# HTML — никогда не кэшируем, браузер всегда берёт свежий
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate